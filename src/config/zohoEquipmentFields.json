{
  "description": "CapStone Zoho CRM field reference for future Asset Capture / Equipments integration.",
  "source": "Zoho CRM MCP metadata export supplied 2026-06-02.",
  "notes": [
    "Use exact picklist actual_value strings when writing to Zoho.",
    "The -None- blank defaults are intentionally omitted; literal None remains where it is an actual selectable value.",
    "Equipments is CustomModule1 in Zoho CRM and uses layout Asset Main.",
    "Subform_1 rows are nested under the parent Equipments record payload, not standalone records.",
    "CapStone asset search uses Zoho word search plus equals/starts_with criteria (never contains — invalid in Zoho). Search field list is capped at 50 Zoho fields.",
    "Flow Meter dynamic fields use zohoApiName in assetFieldRegistry when Zoho CRM api_name differs from CapStone key (e.g. Cal_Factor_K_Factor → Cal_Factor_K_factor_Etc, Sensor_Model_Number → Model_Number).",
    "CapStone Asset Category dropdown includes Flow Meter and Flow Open Channel (Zoho picklist actual_value strings). Deprecated Zoho value Flow is omitted when Flow Meter exists. CapStone never saves Flow when the user selects Flow Meter.",
    "Set Up Input/Output Engineering Units are Zoho lookups to CustomModule8; CapStone loads options from CRM and saves lookup IDs.",
    "Asset category layout activation on Zoho save applies to ALL Asset_Category values. CapStone saves core without category/extension fields, then calls Netlify activate_equipment_category_layout (temp swap + v8 layout_rules + persist). See docs/CAPSTONE_DEVELOPMENT_RULES.md.",
    "Flow Open Channel categorySuggestedDefaults: Display Engineering Units GPM US; Set Up Input H2O Inches; Set Up Output 4-20 mA; Duration 0.75; when Brand Pulsar + Series Ultra 4 → P005, P006, P838, P839.",
    "Flow Meter categorySuggestedDefaults: Display GPM US; Set Up Input GPM US; Set Up Output 4-20 mA; Duration 0.75; same Pulsar Ultra 4 PV parameters as Flow Open Channel.",
    "Duration and Damping_Seconds are separate Zoho Equipments fields — do not merge labels or defaults.",
    "Deal Assets_and_Checklist Instrument_Description is refreshed when an asset is linked again on the same deal."
  ],
  "assetCapturePhase1": {
    "moduleApiName": "Equipments",
    "layoutName": "Asset Main",
    "requiredFields": [
      "Asset_Category",
      "Account",
      "Name",
      "Asset_Function",
      "Building",
      "Additional_Designator",
      "Asset_Brand",
      "Asset_Type",
      "Asset_Model_Number",
      "Serial_Number",
      "Asset_Environment",
      "Confined_Space"
    ],
    "photoExtractionTargets": [
      "Asset_Brand",
      "Asset_Type",
      "Asset_Series",
      "Asset_Model_Number",
      "Serial_Number",
      "Nameplate_Additional_Info"
    ],
    "capstoneContextFields": [
      "Account",
      "Location_Coordinates",
      "Date"
    ],
    "otherExplainFieldMap": {
      "Asset_Function": "If_Asset_is_other_explain",
      "Asset_Brand": "If_Asset_Brand_Other_explain",
      "Asset_Type": "If_Asset_Type_other_explain",
      "Asset_Series": "If_Asset_Series_is_Other_Function_explain"
    }
  },
  "assetFieldRegistry": {
    "Customer_Asset_Number": { "label": "Customer Asset Number", "widget": "text" },
    "Frequency": { "label": "Frequency", "widget": "select", "picklist": "Frequency" },
    "Date_Installed": { "label": "Date Installed", "widget": "date", "zohoApiName": "Date", "optionalReminder": true },
    "Location": { "label": "Location", "widget": "text", "note": "No separate Zoho field; use Location Coordinates on main form" },
    "Room": { "label": "Room (Electrical, Filter, Pump, etc.)", "widget": "text" },
    "Sensor_Model_Number": { "label": "Sensor Model Number", "widget": "text", "zohoApiName": "Model_Number" },
    "Sensor_Serial_Number": { "label": "Sensor Serial Number", "widget": "text", "zohoApiName": "Serial_Number1" },
    "Sensor_Additional_Information": { "label": "Sensor Additional Information", "widget": "textarea", "rows": 2, "zohoApiName": "Sensor_Additional_information" },
    "Engineering_Units": { "label": "Engineering Units", "widget": "select", "picklist": "Engineering_Units" },
    "Display_Size_d_Readability": { "label": "Display Size (d) / Readability", "widget": "text", "zohoApiName": "Instrument_Resolution_Increment_Amount" },
    "Input_Engineering_Units": { "label": "Input Engineering Units", "widget": "lookup", "lookupSource": "engineeringUnits", "zohoApiName": "Measurement_Type_Input" },
    "Input_PV_Zero_Parameter": { "label": "Input PV Zero Parameter", "widget": "text", "zohoApiName": "Empty_Parameter_1" },
    "Input_PV_Zero": { "label": "Input PV @ Zero", "widget": "number", "zohoApiName": "Empty_Distance", "zohoType": "double" },
    "Input_PV_Span_Parameter": { "label": "Input PV Span Parameter", "widget": "text", "zohoApiName": "Span_Parameter_1" },
    "Input_PV_Span": { "label": "Input PV @ Span", "widget": "number", "zohoApiName": "Span_Distance", "zohoType": "double" },
    "Output_Engineering_Units": { "label": "Output Engineering Units", "widget": "lookup", "lookupSource": "engineeringUnits", "zohoApiName": "Measurement_Units_Type_Output" },
    "Output_PV_Zero_Parameter": { "label": "Output PV Zero Parameter", "widget": "text", "zohoApiName": "Output_PV_Zero_Parameter_1" },
    "Output_PV_Zero": { "label": "Output PV @ Zero", "widget": "number", "zohoApiName": "PV_Zero", "zohoType": "double" },
    "Output_PV_Span_Parameter": { "label": "Output PV Span Parameter", "widget": "text", "zohoApiName": "Output_PV_Span_Parameter_1" },
    "Output_PV_Span": { "label": "Output PV @ Span", "widget": "number", "zohoApiName": "PV_Span", "zohoType": "double" },
    "Cal_Factor_K_Factor": { "label": "Cal Factor, K Factor, Etc.", "widget": "text", "zohoApiName": "Cal_Factor_K_factor_Etc" },
    "Pipe_Size": { "label": "Pipe Size", "widget": "select", "picklist": "Pipe_Size" },
    "Duration": { "label": "Duration", "widget": "text", "zohoType": "double" },
    "Damping_Seconds": { "label": "Damping Seconds", "widget": "text", "zohoType": "double" },
    "Flume_Weir_Type": { "label": "Flume / Weir Type", "widget": "select", "picklist": "Flume_Weir_Type" },
    "Flume_Weir_Size_Length": { "label": "Flume / Weir Size / Length", "widget": "text" },
    "Distance_Measurement_Units": { "label": "Distance Measurement Units", "widget": "select", "picklist": "Distance_Measurement_Units" },
    "Exponent": { "label": "Exponent", "widget": "text", "zohoType": "double" },
    "Da1_and_DA2": { "label": "DA1 and DA2", "widget": "multiselect", "picklist": "Da1_and_DA2" },
    "DA2_License_Number": { "label": "DA2 License Number", "widget": "text" },
    "Totalizer_Display": { "label": "Totalizer Display Units", "widget": "select", "picklist": "Totalizer_Display" },
    "Rosemount_LOI_Display": { "label": "Rosemount LOI Display", "widget": "select", "picklist": "Display", "zohoApiName": "Display" }
  },
  "engineeringUnitsLookup": {
    "moduleApiName": "CustomModule8",
    "nameField": "Name"
  },
  "categoryLayouts": {
    "Flow Meter": {
      "sections": [
        {
          "id": "assetInfoExtras",
          "title": "Asset Information (additional)",
          "fields": ["Customer_Asset_Number", "Frequency", "Date_Installed", "Location", "Room"]
        },
        {
          "id": "sensor",
          "title": "Sensor (Other attached Parts)",
          "fields": ["Sensor_Model_Number", "Sensor_Serial_Number", "Sensor_Additional_Information"]
        },
        {
          "id": "display",
          "title": "Display Information",
          "fields": ["Engineering_Units", "Display_Size_d_Readability"]
        },
        {
          "id": "setupInput",
          "title": "Set Up Input",
          "fields": ["Input_Engineering_Units", "Input_PV_Zero_Parameter", "Input_PV_Zero", "Input_PV_Span_Parameter", "Input_PV_Span"]
        },
        {
          "id": "durationDamping",
          "title": "Duration & Damping",
          "fields": ["Duration", "Damping_Seconds"]
        },
        {
          "id": "setupOutput",
          "title": "Set Up Output",
          "fields": ["Output_Engineering_Units", "Output_PV_Zero_Parameter", "Output_PV_Zero", "Output_PV_Span_Parameter", "Output_PV_Span"]
        },
        {
          "id": "flowMeterDetails",
          "title": "Flow Meter Details",
          "fields": ["Cal_Factor_K_Factor", "Pipe_Size"]
        },
        {
          "id": "subform",
