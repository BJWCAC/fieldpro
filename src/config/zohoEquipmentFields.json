  "categorySuggestedDefaults": {
    "Flow Open Channel": {
      "fields": {
        "Engineering_Units": "GPM US",
        "Input_Engineering_Units": { "lookup": ["H2O Inches", "Inches H2O", "In H2O"] },
        "Output_Engineering_Units": { "lookup": ["4-20 mA", "4-20mA"] },
        "Duration": "0.75"
      },
      "conditional": [
        {
          "when": { "brand": "Pulsar", "series": "Ultra 4" },
          "fields": {
            "Input_PV_Zero_Parameter": "P005",
            "Input_PV_Span_Parameter": "P006",
            "Output_PV_Zero_Parameter": "P838",
            "Output_PV_Span_Parameter": "P839"
          }
        }
      ]
    },
    "Flow Meter": {
      "fields": {
        "Engineering_Units": "GPM US",
        "Input_Engineering_Units": { "lookup": ["GPM US"] },
        "Output_Engineering_Units": { "lookup": ["4-20 mA", "4-20mA"] },
        "Duration": "0.75"
      },
      "conditional": [
        {
          "when": { "brand": "Pulsar", "series": "Ultra 4" },
          "fields": {
            "Input_PV_Zero_Parameter": "P005",
            "Input_PV_Span_Parameter": "P006",
            "Output_PV_Zero_Parameter": "P838",
            "Output_PV_Span_Parameter": "P839"
          }
        }
      ]
    }
